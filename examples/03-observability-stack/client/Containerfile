# Multi-stage, UBI-based image for the Python 3.14 OTLP client.
#
# Stage 1 (builder): install dependencies into a venv using the full UBI
# python image (has pip, build tooling).
# Stage 2 (runtime): copy the venv into the slim UBI micro/minimal python
# image — no pip or build tooling in the shipped layer.

# ---- builder ----------------------------------------------------------------
FROM registry.access.redhat.com/ubi9/python-314:latest AS builder
WORKDIR /build
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# ---- runtime ----------------------------------------------------------------
FROM registry.access.redhat.com/ubi9/python-314-minimal:latest AS runtime
WORKDIR /app
# Bring only the resolved virtualenv across; no pip/build layers.
COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
COPY client.py ./

# From inside rootless Podman, the host stack is host.containers.internal.
ENV OTEL_EXPORTER_OTLP_ENDPOINT=http://host.containers.internal:4318 \
    OTEL_SERVICE_NAME=ebpf-client

ENTRYPOINT ["python", "client.py"]
