#cloud-config
# cloud-init user-data template for an eBPF target/peer guest.
# Placeholders __HOSTNAME__ and __SSH_PUBKEY__ are filled by provision-vm.sh.
hostname: __HOSTNAME__
fqdn: __HOSTNAME__.lab

users:
  - name: fedora
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: [wheel]
    shell: /bin/bash
    lock_passwd: true
    ssh_authorized_keys:
      - __SSH_PUBKEY__

# Grow the root filesystem to fill the overlay disk.
growpart:
  mode: auto
  devices: ['/']

package_update: true

# Everything an eBPF target needs, all from Fedora repositories.
# kernel-devel + the matching BTF give CO-RE programs their type info;
# clang/llvm + bpftool/bpftrace/bcc are the kernel-side toolchain we
# cross-check Aya against; kernel-tools brings turbostat for the power
# chapter; jq/openssl are used by demos and cross-checks throughout.
packages:
  - kernel-devel
  - kernel-headers
  - clang
  - llvm
  - bpftool
  - bpftrace
  - bcc-tools
  - libbpf-tools          # precompiled CO-RE versions of the bcc tools (Ch 66)
  - libbpf-devel          # bpf/bpf_helpers.h etc. to compile reference .bpf.c (Ch 49, 55, 57)
  - perf
  - kernel-tools          # turbostat / cpupower / x86_energy_perf_policy (Ch 61)
  - elfutils-libelf-devel
  - zlib-devel
  - jq                    # parse bpftool -j / Tempo JSON (Ch 62, 65, 66)
  - openssl               # traceparent ids + TLS targets (Ch 14, 62, 63)
  - git
  - tar
  # Containers ON the target VM: observed app targets (Quarkus/FastAPI) run
  # here under Podman/crun so the VM's kernel — where our eBPF attaches — can
  # see their processes. dwarves provides pahole (BTF from DWARF, Ch 15).
  - podman
  - podman-compose
  - crun
  - dwarves
  # networking chapters (Part 5): traffic generators + inspection on both VMs
  - nmap-ncat
  - socat
  - iproute
  - iputils
  - curl
  - tcpdump

runcmd:
  # Confirm the running kernel ships a BTF blob (required for CO-RE).
  - [ bash, -c, "test -f /sys/kernel/btf/vmlinux && echo 'BTF: present' > /var/log/ebpf-target-ready || echo 'BTF: MISSING' > /var/log/ebpf-target-ready" ]
  - [ bash, -c, "uname -r >> /var/log/ebpf-target-ready" ]
  - [ bash, -c, "touch /var/lib/cloud/ebpf-provisioned" ]

final_message: "eBPF target __HOSTNAME__ is up after $UPTIME seconds"
